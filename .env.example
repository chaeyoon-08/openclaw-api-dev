# Telegram @BotFather 에서 발급받은 봇 토큰 값
TELEGRAM_BOT_TOKEN=

# Google Web Client 정보
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Google 이메일 계정 주소
GOOGLE_ACCOUNT=

# Anthropic API 키
ANTHROPIC_API_KEY=

# 에이전트별 모델 설정
# orchestrator: 계획 수립·판단·종합 담당 (예: anthropic/claude-sonnet-4-6)
ORCHESTRATOR_MODEL=anthropic/claude-sonnet-4-6
# mail/calendar/drive: 각 서비스 전담 (예: anthropic/claude-haiku-4-5)
MAIL_MODEL=anthropic/claude-haiku-4-5
CALENDAR_MODEL=anthropic/claude-haiku-4-5
DRIVE_MODEL=anthropic/claude-haiku-4-5
# fallback: 대체 모델
FALLBACK_MODEL=anthropic/claude-haiku-4-5

# MEMORY.md 백업 폴더 (Google Drive, 기본값: openclaw-memory)
DRIVE_MEMORY_FOLDER=
